# ===========================================
# Fofitos Recipe Nutrition - Environment
# ===========================================
# Copy to .env and fill in values.
# Use LOCAL values for development (supabase start).
# Use PRODUCTION values for deployed Supabase Cloud.
# ===========================================

# --- DATABASE (plain PostgreSQL - for db:init) ---
# Used by: npm run db:init
# Escape $ in password with $$ in .env
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/fofitos_db

# --- LOCAL (Supabase local / Docker) ---
# After running: npx supabase start
# API URL and anon key are printed; defaults:
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# --- PRODUCTION (Supabase Cloud) ---
# Get from: Supabase Dashboard > Project Settings > API
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
